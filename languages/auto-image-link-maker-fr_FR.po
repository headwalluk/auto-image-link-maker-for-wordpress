msgstr "Sélecteurs CSS"

#: includes/class-settings.php:99
msgid "Image Selectors"
msgstr "Sélecteurs d'images"

#: includes/class-settings.php:107
msgid "Page Types"
msgstr "Page Types"

#: includes/class-settings.php:114
